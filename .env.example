# Public browser configuration
# Leave blank to run the typed fixture boundary without a Convex deployment.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_REVENUE_ENABLED=false
NEXT_PUBLIC_DODO_CHECKOUT_HOST=checkout.dodopayments.com
NEXT_PUBLIC_DODO_PRODUCT_ID=

# Configure these as server-side Convex environment variables, not browser variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional: set only when using another OpenAI-compatible provider.
OPENAI_BASE_URL=
LINKUP_API_KEY=
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
# Required comma-separated checkout product allowlist when payments are enabled.
DODO_PRODUCT_IDS=
# Trusted application origin used to validate payment return URLs.
APP_ORIGIN=http://localhost:3000
