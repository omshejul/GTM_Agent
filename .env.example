# Public browser configuration
# Leave blank to run the typed fixture boundary without a Convex deployment.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_REVENUE_ENABLED=false

# Configure these as server-side Convex environment variables, not browser variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional: set only when using another OpenAI-compatible provider.
OPENAI_BASE_URL=
LINKUP_API_KEY=
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
